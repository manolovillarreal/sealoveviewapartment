<!-- â”€â”€â”€ GALLERY â”€â”€â”€ -->
<section id="gallery">
  <div class="container">
    <div class="fade-in" style="text-align:center;max-width:600px;margin:0 auto 48px;">
      <span class="section-label">Galería</span>
      <h2 class="section-title">Explora cada rincón</h2>
      <div class="divider" style="margin:20px auto;"></div>
      <p class="section-sub">Descubre los detalles que hacen de Sea Love View el lugar perfecto para tus vacaciones.</p>
    </div>
    <div class="gallery-grid fade-in">
      <img src="/sealoveviewapartment/img/sala_1.jpeg" alt="Sala 1" class="gallery-img double-w" loading="lazy">
      <img src="/sealoveviewapartment/img/comedor_zoom.jpeg" alt="Comedor" class="gallery-img" loading="lazy">
      <img src="/sealoveviewapartment/img/estar_lectura.jpeg" alt="Estar de lectura" class="gallery-img" loading="lazy">
      
      <img src="/sealoveviewapartment/img/habitacion_principal_2.jpeg" alt="Habitación principal 2" class="gallery-img" loading="lazy">
      <img src="/sealoveviewapartment/img/habitacion_social_2.jpeg" alt="Habitación social 2" class="gallery-img" loading="lazy">
      <img src="/sealoveviewapartment/img/habitacion_principal.jpeg" alt="Habitación principal" class="gallery-img double-w" loading="lazy">
      
      <img src="/sealoveviewapartment/img/bano_1.jpeg" alt="Baño 1" class="gallery-img" loading="lazy">
      <img src="/sealoveviewapartment/img/habitacion_social.jpeg" alt="Habitación social" class="gallery-img double-w" loading="lazy">
      
      <img src="/sealoveviewapartment/img/bano_2.jpeg" alt="Baño 2" class="gallery-img" loading="lazy">
    </div>
  </div>
</section>

<!-- Lightbox Modal -->
<div id="lightbox" class="lightbox">
  <span class="lightbox-close">&times;</span>
  <img id="lightbox-img" class="lightbox-content" alt="Lightbox Image">
</div>
