<section id="jota">
  <div class="container">
    <div class="jota-inner">
      <div class="fade-in">
        <span class="section-label">Arte Local</span>
        <h2 class="section-title" style="color:white">Descubre el arte<br>de <em style="color:var(--coral-light)">Jota Art</em></h2>
        <div class="divider"></div>
        <p class="section-sub">Jota es un artista local que ha creado murales en toda la isla, promoviendo la protección ambiental, los valores, el amor y una imagen positiva de Colombia.</p>
        <div style="margin-top:30px;">
          <div class="jota-stat">40+</div>
          <div class="jota-stat-label">Murales en San Andrés</div>
        </div>
        <p style="font-size:0.86rem;color:rgba(255,255,255,0.6);line-height:1.7;max-width:420px;margin-bottom:24px;">Cada mural cuenta una historia del Caribe, de su gente y de la necesidad de proteger este paraíso natural para las generaciones futuras.</p>
        <div class="jota-links">
          <a href="https://instagram.com/Jota_Art" target="_blank" class="jota-link" style="display:flex;align-items:center;gap:8px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            @Jota_Art
          </a>
        </div>
      </div>
      <div class="jota-murals fade-in" style="position:relative;">        
        <div class="jota-mural" style="background:url('/sealoveviewapartment/img/Arte_1.png') center/cover;"></div>
        <div class="jota-mural" style="background:url('/sealoveviewapartment/img/Arte_2.jpg') center/cover;margin-top:0;"></div>
      </div>
    </div>
  </div>
</section>
